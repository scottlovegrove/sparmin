{
    "plugins": ["typescript", "oxc", "unicorn", "import"],
    "categories": {},
    "rules": {
        "no-unused-vars": [
            "error",
            {
                "args": "all",
                "argsIgnorePattern": "^_",
                "vars": "all",
                "varsIgnorePattern": "^_",
                "caughtErrors": "all",
                "caughtErrorsIgnorePattern": "^_",
                "ignoreRestSiblings": false
            }
        ],
        "no-unused-private-class-members": "error",
        "import/no-namespace": "error"
    },
    "ignorePatterns": [
        "**/dist/**",
        "**/node_modules/**",
        "**/.astro/**",
        "**/*.astro",
        "**/worker-configuration.d.ts"
    ]
}
