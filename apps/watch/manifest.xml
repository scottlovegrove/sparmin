<?xml version="1.0" encoding="UTF-8"?>
<!--
    Connect IQ application manifest.
    Generated once, then hand-edited. The `id` is a stable per-app UUID and
    must never change once the app is published, or the store treats it as a
    different app. Add or remove supported devices in the <iq:products> list;
    each id must match a device the installed SDK knows about.
-->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application
        entry="SparminApp"
        id="f3c85948a3494dccac4d28661e0550ab"
        launcherIcon="@Drawables.LauncherIcon"
        minApiLevel="3.1.0"
        name="@Strings.AppName"
        type="watch-app">

