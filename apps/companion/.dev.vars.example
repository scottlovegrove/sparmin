# Copy to .dev.vars (git-ignored) for local development.
#
# ENVIRONMENT=development makes the magic link print to the wrangler console
# instead of being emailed, so the app works without an email provider.
ENVIRONMENT=development
BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_SECRET=a-long-random-string-just-for-local-dev
EMAIL_FROM=Sparmin <hello@sparmin.scottlovegrove.co.uk>

# Leave unset to print magic links to the console. Set it to send real mail.
# RESEND_API_KEY=re_...
