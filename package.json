{
  "name": "sparmin",
  "version": "0.0.0",
  "private": true,
  "description": "Sparmin monorepo — Garmin Connect IQ watch app + marketing website.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build:watch": "npm run build -w @sparmin/watch",
    "dev:marketing": "npm run dev -w @sparmin/marketing",
    "build:marketing": "npm run build -w @sparmin/marketing",
    "preview:marketing": "npm run preview -w @sparmin/marketing",
    "dev:companion": "npm run dev -w @sparmin/companion",
    "build:companion": "npm run build -w @sparmin/companion",
    "test:companion": "npm run test -w @sparmin/companion",
    "secret:companion": "npm run secret -w @sparmin/companion --",
    "secrets:companion": "npm run secrets -w @sparmin/companion",
    "check": "oxlint apps/marketing/src apps/companion/src apps/companion/worker apps/companion/test && oxfmt --check",
    "fix": "oxlint apps/marketing/src apps/companion/src apps/companion/worker apps/companion/test --fix && oxfmt"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "npm-run-all2": "9.0.2",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.3"
  }
}
